const categoryDescription =
  localizedCategoryDescriptions[lang]?.[categorySlug] ?? localizedCategoryDescriptions.en[categorySlug];
const localePaths = (Object.keys(LOCALES) as Lang[]).map((targetLang) => ({
  lang: targetLang,
  path: getBlogPermalink(targetLang),
}));

const metadata = {
  title: `${copy.category}: ${category.title}${currentPage > 1 ? ` — ${copy.page} ${currentPage}` : ''}`,
  description: categoryDescription ?? `${copy.subtitle} ${copy.category}: ${category.title}.`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata} i18n lang={lang} localePaths={localePaths} alternateLinks={[]}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline>{category.title}</Headline>
    {
      categoryDescription && currentPage === 1 && (
        <p class="mx-auto mb-10 max-w-3xl text-center text-lg text-muted dark:text-slate-400">{categoryDescription}</p>
      )
    }
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} lang={lang} />
  </section>
</Layout>
